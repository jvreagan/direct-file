<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/form1099Bs">
      <Name>1099-B forms</Name>
      <Description>Collection of Form 1099-B broker transaction reports</Description>
      <Writable>
        <Collection />
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/brokerName">
      <Name>Broker name</Name>
      <Description>Name of the broker or barter exchange</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="MaxLength">
          <Int>75</Int>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/brokerTin">
      <Name>Broker TIN</Name>
      <Description>Broker's taxpayer identification number</Description>
      <Export mef="true" />
      <Writable>
        <EIN />
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/description">
      <Name>Description of property</Name>
      <Description>Description of property sold (1099-B, Box 1a)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="MaxLength">
          <Int>100</Int>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/dateAcquired">
      <Name>Date acquired</Name>
      <Description>Date acquired (1099-B, Box 1b)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="Match">
          <String><![CDATA[\d{4}-\d{2}-\d{2}]]></String>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/dateSold">
      <Name>Date sold or disposed</Name>
      <Description>Date sold or disposed (1099-B, Box 1c)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="Match">
          <String><![CDATA[\d{4}-\d{2}-\d{2}]]></String>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/proceeds">
      <Name>Proceeds</Name>
      <Description>Proceeds (1099-B, Box 1d)</Description>
      <Export mef="true" />
      <Writable>
        <Dollar />
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/costBasis">
      <Name>Cost or other basis</Name>
      <Description>Cost or other basis (1099-B, Box 1e)</Description>
      <Export mef="true" />
      <Writable>
        <Dollar />
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/washSaleDisallowed">
      <Name>Wash sale loss disallowed</Name>
      <Description>Wash sale loss disallowed (1099-B, Box 1g)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/form1099Bs/*/federalTaxWithheld">
      <Name>Federal income tax withheld</Name>
      <Description>Federal income tax withheld (1099-B, Box 4)</Description>
      <Export mef="true" />
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/form1099Bs/*/isShortTerm">
      <Name>Short-term transaction</Name>
      <Description>Whether the holding period is one year or less (1099-B, Box 2)</Description>
      <Writable>
        <Boolean />
      </Writable>
    </Fact>

    <Fact path="/form1099Bs/*/basisReportedToIRS">
      <Name>Basis reported to IRS</Name>
      <Description>Whether cost basis was reported to the IRS (1099-B, Box 12)</Description>
      <Writable>
        <Boolean />
      </Writable>
      <Placeholder>
        <False />
      </Placeholder>
    </Fact>

    <Fact path="/form1099Bs/*/gainOrLoss">
      <Name>Gain or loss</Name>
      <Description>Computed gain or loss from this transaction</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Add>
            <Subtract>
              <Minuend>
                <Dependency path="../proceeds" />
              </Minuend>
              <Subtrahends>
                <Dependency path="../costBasis" />
              </Subtrahends>
            </Subtract>
            <Dependency path="../washSaleDisallowed" />
          </Add>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/form1099Bs/*/isComplete">
      <Description>Whether this 1099-B entry is complete</Description>
      <Derived>
        <All>
          <IsComplete>
            <Dependency path="../description" />
          </IsComplete>
          <IsComplete>
            <Dependency path="../dateSold" />
          </IsComplete>
          <IsComplete>
            <Dependency path="../proceeds" />
          </IsComplete>
          <IsComplete>
            <Dependency path="../costBasis" />
          </IsComplete>
        </All>
      </Derived>
    </Fact>

    <Fact path="/total1099BWithholding">
      <Name>Total 1099-B withholding</Name>
      <Description>Sum of federal tax withheld from all 1099-Bs</Description>
      <Export downstreamFacts="true" />
      <Derived>
        <Round>
          <CollectionSum>
            <Dependency path="/form1099Bs/*/federalTaxWithheld" />
          </CollectionSum>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/hasForm1099Bs">
      <Description>Whether the taxpayer has any 1099-B forms</Description>
      <Export downstreamFacts="true" />
      <Derived>
        <GreaterThan>
          <Left>
            <CollectionSize>
              <Dependency path="/form1099Bs" />
            </CollectionSize>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>

    <Fact path="/hasIncompleteForm1099Bs">
      <Description>Whether any 1099-B is incomplete</Description>
      <BlockSubmissionOnTrue />
      <Derived>
        <GreaterThan>
          <Left>
            <Count>
              <Not>
                <Dependency path="/form1099Bs/*/isComplete" />
              </Not>
            </Count>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
