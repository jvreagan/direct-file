    <Fact path="/scheduleEProperties/*/totalExpenses">
      <Name>Total expenses</Name>
      <Description>Total rental expenses (Schedule E, Line 20)</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Add>
            <Dependency path="../advertising" />
            <Dependency path="../autoAndTravel" />
            <Dependency path="../cleaning" />
            <Dependency path="../insurance" />
            <Dependency path="../legal" />
            <Dependency path="../management" />
            <Dependency path="../mortgageInterest" />
            <Dependency path="../repairs" />
            <Dependency path="../supplies" />
            <Dependency path="../taxes" />
            <Dependency path="../utilities" />
            <Dependency path="../depreciation" />
            <Dependency path="../otherExpenses" />
          </Add>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/scheduleEProperties/*/netIncome">
      <Name>Net rental income or loss</Name>
      <Description>Net income or loss for this property (Schedule E, Line 21)</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Subtract>
            <Minuend>
              <Dependency path="../rentsReceived" />
            </Minuend>
            <Subtrahends>
              <Dependency path="../totalExpenses" />
            </Subtrahends>
          </Subtract>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/scheduleEProperties/*/isComplete">
      <Description>Whether this rental property entry is complete</Description>
      <Derived>
        <All>
          <IsComplete>
            <Dependency path="../propertyAddress" />
          </IsComplete>
          <IsComplete>
            <Dependency path="../rentsReceived" />
          </IsComplete>
        </All>
      </Derived>
    </Fact>

    <Fact path="/totalScheduleERentalIncome">
      <Name>Total Schedule E rental income</Name>
      <Description>Sum of net rental income from all properties (Schedule E, Line 26)</Description>
      <Export downstreamFacts="true" mef="true" />
      <Derived>
        <Round>
          <CollectionSum>
            <Dependency path="/scheduleEProperties/*/netIncome" />
          </CollectionSum>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/hasScheduleE">
      <Description>Whether the taxpayer has any Schedule E properties</Description>
      <Export downstreamFacts="true" />
      <Derived>
        <GreaterThan>
          <Left>
            <CollectionSize>
              <Dependency path="/scheduleEProperties" />
            </CollectionSize>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>

    <Fact path="/hasIncompleteScheduleE">
      <Description>Whether any Schedule E property is incomplete</Description>
      <BlockSubmissionOnTrue />
      <Derived>
        <GreaterThan>
          <Left>
            <Count>
              <Not>
                <Dependency path="/scheduleEProperties/*/isComplete" />
              </Not>
            </Count>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
