<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/scheduleEProperties">
      <Name>Rental properties</Name>
      <Description>Collection of rental real estate properties for Schedule E</Description>
      <Writable>
        <Collection />
      </Writable>
    </Fact>

    <Fact path="/scheduleEProperties/*/propertyAddress">
      <Name>Property address</Name>
      <Description>Street address of the rental property (Schedule E, Line 1a)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="MaxLength">
          <Int>100</Int>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/scheduleEProperties/*/propertyType">
      <Name>Property type</Name>
      <Description>Type of rental property (Schedule E, Line 1b)</Description>
      <Export mef="true" />
      <Writable>
        <Enum optionsPath="/scheduleEPropertyTypes" />
      </Writable>
    </Fact>

