    <Fact path="/scheduleCs/*/rent">
      <Name>Rent or lease</Name>
      <Description>Rent or lease of business property (Schedule C, Line 20b)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/supplies">
      <Name>Supplies</Name>
      <Description>Supplies (Schedule C, Line 22)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/utilities">
      <Name>Utilities</Name>
      <Description>Utilities (Schedule C, Line 25)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/otherExpenses">
      <Name>Other expenses</Name>
      <Description>Other business expenses (Schedule C, Line 27a)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/totalExpenses">
      <Name>Total expenses</Name>
      <Description>Total expenses before business use of home (Schedule C, Line 28)</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Add>
            <Dependency path="../advertising" />
            <Dependency path="../carAndTruckExpenses" />
            <Dependency path="../commissions" />
            <Dependency path="../insurance" />
            <Dependency path="../interestMortgage" />
            <Dependency path="../interestOther" />
            <Dependency path="../officeExpense" />
            <Dependency path="../rent" />
            <Dependency path="../supplies" />
            <Dependency path="../utilities" />
            <Dependency path="../otherExpenses" />
          </Add>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/scheduleCs/*/netProfit">
      <Name>Net profit or loss</Name>
      <Description>Net profit or loss (Schedule C, Line 31)</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Subtract>
            <Minuend>
              <Dependency path="../grossIncomeWithOther" />
            </Minuend>
            <Subtrahends>
              <Dependency path="../totalExpenses" />
            </Subtrahends>
          </Subtract>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/scheduleCs/*/isComplete">
      <Description>Whether this Schedule C entry is complete</Description>
      <Derived>
        <All>
          <IsComplete>
            <Dependency path="../businessName" />
          </IsComplete>
          <IsComplete>
            <Dependency path="../grossReceipts" />
          </IsComplete>
        </All>
      </Derived>
    </Fact>

    <Fact path="/totalScheduleCNetProfit">
      <Name>Total Schedule C net profit</Name>
      <Description>Sum of net profit from all Schedule C businesses</Description>
      <Export downstreamFacts="true" mef="true" />
      <Derived>
        <Round>
          <CollectionSum>
            <Dependency path="/scheduleCs/*/netProfit" />
          </CollectionSum>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/hasScheduleC">
      <Description>Whether the taxpayer has any Schedule C businesses</Description>
      <Export downstreamFacts="true" />
      <Derived>
        <GreaterThan>
          <Left>
            <CollectionSize>
              <Dependency path="/scheduleCs" />
            </CollectionSize>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>

    <Fact path="/hasIncompleteScheduleCs">
      <Description>Whether any Schedule C entry is incomplete</Description>
      <BlockSubmissionOnTrue />
      <Derived>
        <GreaterThan>
          <Left>
            <Count>
              <Not>
                <Dependency path="/scheduleCs/*/isComplete" />
              </Not>
            </Count>
          </Left>
          <Right>
            <Int>0</Int>
          </Right>
        </GreaterThan>
      </Derived>
    </Fact>
  </Facts>
</FactDictionaryModule>
