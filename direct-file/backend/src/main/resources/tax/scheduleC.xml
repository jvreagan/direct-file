<?xml-model href="./FactDictionaryModule.rng"?>
<FactDictionaryModule>
  <Facts>
    <Fact path="/scheduleCs">
      <Name>Schedule C businesses</Name>
      <Description>Collection of Schedule C business activities</Description>
      <Writable>
        <Collection />
      </Writable>
    </Fact>

    <Fact path="/scheduleCs/*/businessName">
      <Name>Business name</Name>
      <Description>Principal business or profession name (Schedule C, Line A)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="MaxLength">
          <Int>75</Int>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/scheduleCs/*/businessCode">
      <Name>Business activity code</Name>
      <Description>Principal business code (Schedule C, Line B)</Description>
      <Export mef="true" />
      <Writable>
        <String />
        <Limit type="Match">
          <String><![CDATA[\d{6}]]></String>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/scheduleCs/*/ein">
      <Name>Employer ID number</Name>
      <Description>Employer ID number (Schedule C, Line D)</Description>
      <Export mef="true" />
      <Writable>
        <EIN />
      </Writable>
    </Fact>

    <Fact path="/scheduleCs/*/accountingMethod">
      <Name>Accounting method</Name>
      <Description>Cash, accrual, or other (Schedule C, Line F)</Description>
      <Export mef="true" />
      <Writable>
        <Enum optionsPath="/scheduleCAccountingMethods" />
      </Writable>
    </Fact>

    <!-- Income (Part I) -->
    <Fact path="/scheduleCs/*/grossReceipts">
      <Name>Gross receipts or sales</Name>
      <Description>Gross receipts or sales (Schedule C, Line 1)</Description>
      <Export mef="true" />
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
    </Fact>

    <Fact path="/scheduleCs/*/returnsAndAllowances">
      <Name>Returns and allowances</Name>
      <Description>Returns and allowances (Schedule C, Line 2)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/costOfGoodsSold">
      <Name>Cost of goods sold</Name>
      <Description>Cost of goods sold (Schedule C, Line 4)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/grossIncome">
      <Name>Gross income</Name>
      <Description>Gross income (Schedule C, Line 5)</Description>
      <Export mef="true" />
      <Derived>
        <Round>
          <Subtract>
            <Minuend>
              <Subtract>
                <Minuend>
                  <Dependency path="../grossReceipts" />
                </Minuend>
                <Subtrahends>
                  <Dependency path="../returnsAndAllowances" />
                </Subtrahends>
              </Subtract>
            </Minuend>
            <Subtrahends>
              <Dependency path="../costOfGoodsSold" />
            </Subtrahends>
          </Subtract>
        </Round>
      </Derived>
    </Fact>

    <Fact path="/scheduleCs/*/otherIncome">
      <Name>Other income</Name>
      <Description>Other business income (Schedule C, Line 6)</Description>
      <Writable>
        <Dollar />
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

    <Fact path="/scheduleCs/*/grossIncomeWithOther">
      <Description>Gross income plus other income (Schedule C, Line 7)</Description>
      <Derived>
        <Round>
          <Add>
            <Dependency path="../grossIncome" />
            <Dependency path="../otherIncome" />
          </Add>
        </Round>
      </Derived>
    </Fact>

    <!-- Expenses (Part II - simplified) -->
    <Fact path="/scheduleCs/*/advertising">
      <Name>Advertising</Name>
      <Description>Advertising expenses (Schedule C, Line 8)</Description>
      <Writable>
        <Dollar />
        <Limit type="Min">
          <Dollar>0</Dollar>
        </Limit>
      </Writable>
      <Placeholder>
        <Dollar>0</Dollar>
      </Placeholder>
    </Fact>

